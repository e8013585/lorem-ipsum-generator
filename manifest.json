{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "Lorem Ipsum Generator",
  "version": "1.0.0",
  "description": "Instantly generate Lorem Ipsum placeholder text by paragraphs, words, bytes, or lists.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lorem Ipsum Generator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ]
}